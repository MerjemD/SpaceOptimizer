<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SpaceOptimizer"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/dark_green"
            android:fontFamily="@font/judson_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analiza prostora"
            android:textSize="18sp"
            android:textColor="@color/soft_green"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/project_card_bg"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Space Score"
                android:textSize="18sp"
                android:textColor="@color/soft_green"/>

            <TextView
                android:id="@+id/scoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85%"
                android:textStyle="bold"
                android:textSize="50sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/project_card_bg"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginTop="20dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Preporuke"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/dark_green"/>

            <TextView
                android:id="@+id/recommendationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preporuke..."
                android:textSize="17sp"
                android:textColor="@color/black"
                android:layout_marginTop="14dp"/>

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sačuvaj projekat"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/dark_green"
                android:textColor="@color/cream"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/project_card_bg"
            android:padding="24dp"
            android:layout_marginTop="20dp"
            android:elevation="6dp">

            <TextView
                android:id="@+id/roomSizeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tlocrt prostorije"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/dark_green"/>

            <RelativeLayout
                android:id="@+id/roomLayout"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:background="@drawable/room_background">

                <LinearLayout
                    android:id="@+id/bedView"
                    android:layout_width="110dp"
                    android:layout_height="160dp"
                    android:layout_alignParentLeft="true"
                    android:layout_marginLeft="18dp"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:background="@drawable/bed_bg"
                    android:gravity="top|center"
                    android:paddingTop="10dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="70dp"
                        android:layout_height="20dp"
                        android:background="#DCE6F2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Krevet"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="45dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/closetView"
                    android:layout_width="60dp"
                    android:layout_height="200dp"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="18dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/closet_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ormar"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/sofaView"
                    android:layout_width="160dp"
                    android:layout_height="65dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginLeft="18dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/sofa_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sofa"
                        android:textStyle="bold"
                        android:textColor="#222222"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tableView"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerHorizontal="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/table_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sto"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tvView"
                    android:layout_width="120dp"
                    android:layout_height="35dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/tv_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TV Komoda"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/deskView"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/desk_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sto radni"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chairView"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerHorizontal="true"
                    android:layout_above="@id/sofaView"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/chair_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stolica"
                        android:textStyle="bold"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/bookshelfView"
                    android:layout_width="80dp"
                    android:layout_height="30dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="10dp"
                    android:background="@drawable/bookshelf_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Polica"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/kitchenView"
                    android:layout_width="130dp"
                    android:layout_height="55dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginRight="18dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/kitchen_bg"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kuhinja"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>