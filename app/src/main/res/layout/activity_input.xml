<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unos prostora"
            android:textSize="32sp"
            android:fontFamily="@font/judson_bold"
            android:textStyle="bold"
            android:textColor="#111111"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dodajte dimenzije prostorije"
            android:textSize="17sp"
            android:textColor="#777777"
            android:layout_marginTop="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Naziv projekta"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/projectNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="npr. Modern Living Room"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginTop="8dp"/>

        <!-- WIDTH -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Širina sobe"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/widthInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="npr. 4"
            android:inputType="numberDecimal"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginTop="8dp"/>

        <!-- LENGTH -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dužina sobe"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/lengthInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="npr. 5"
            android:inputType="numberDecimal"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginTop="8dp"/>

        <!-- BUTTON -->

        <Button
            android:id="@+id/nextBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nastavi"
            android:textSize="18sp"
            android:layout_marginTop="35dp"
            android:padding="16dp"
            android:textAllCaps="false"
            android:background="@drawable/button_bg"
            android:textColor="@color/cream"/>

    </LinearLayout>

</ScrollView>