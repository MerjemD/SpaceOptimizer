<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Odabir namještaja"
            android:textSize="32sp"
            android:fontFamily="@font/judson_bold"
            android:textStyle="bold"
            android:textColor="@color/dark_green"/>

        <CheckBox
            android:id="@+id/bedCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Krevet"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/bedWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/bedLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/sofaCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sofa"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/sofaWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/sofaLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/tableCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sto"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/tableWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/tableLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/closetCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ormar"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/closetWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/closetLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/tvCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TV Komoda"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/tvWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/tvLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/deskCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Radni sto"
            android:textColor="@color/dark_green"
            android:textSize="20sp"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/deskWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/deskLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/chairCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stolica"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/chairWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/chairLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/bookshelfCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Polica za knjige"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/bookshelfWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/bookshelfLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/kitchenCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kuhinja"
            android:textSize="20sp"
            android:textColor="@color/dark_green"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/kitchenWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Širina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>

            <EditText
                android:id="@+id/kitchenLength"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dužina (m)"
                android:textColor="@color/dark_green"
                android:textColorHint="#7A7A7A"
                android:inputType="numberDecimal"
                android:backgroundTint="@color/dark_green"/>
        </LinearLayout>

        <Button
            android:id="@+id/analyzeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analiziraj prostor"
            android:textAllCaps="false"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/cream"
            android:backgroundTint="@color/dark_green"
            android:layout_marginTop="40dp"/>

    </LinearLayout>
</ScrollView>